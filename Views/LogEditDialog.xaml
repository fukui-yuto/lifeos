<Window x:Class="LifeOS.Views.LogEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="学習記録の追加" Height="360" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="科目" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="SubjectBox" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="2" Text="トピック" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="TopicBox" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4" Text="学習時間（分）" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="5" x:Name="DurationBox" Text="30" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="6" Text="メモ" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="7" x:Name="NoteBox" Height="60"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Click="Cancel_Click" Margin="0,0,8,0" Padding="16,8"/>
            <Button Content="保存" Click="Save_Click" Padding="16,8"
                    Background="#5B6BF5" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
